(rule
 (targets
  (dir build))
 (mode promote)
 (deps
  soupault.toml
  (source_tree plugins)
  (source_tree templates)
  (source_tree site)
  (source_tree odoc)
  site/docs/nx/api_nav.html
  site/docs/rune/api_nav.html
  site/docs/kaun/api_nav.html
  site/docs/saga/api_nav.html
  site/docs/sowilo/api_nav.html
  site/docs/quill/api_nav.html
  site/docs/hugin/api_nav.html
  site/docs/talon/api_nav.html
  site/docs/fehu/api_nav.html
  )
 (action
  (run soupault)))

