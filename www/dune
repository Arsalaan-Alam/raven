; Generate API documentation pages from odoc output
(subdir site/docs/nx
 (rule
  (mode promote)
  (deps
   (:postprocess ../../../postprocess/index.exe)
   (alias ../../../../doc))
  (targets
   (dir api)
   api_nav.html)
  (action
   (run %{postprocess} nx ../../../../_doc/_html/nx api api_nav.html))))

